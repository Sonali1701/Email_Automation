# Copy this file to ".env" and fill in your values.

# --- Microsoft Graph (Azure app registration) ---
# Application (client) ID from your Azure app registration.
GRAPH_CLIENT_ID=
# Directory (tenant) ID, or "common" / "organizations". Use your tenant ID for a
# single-tenant work account; "common" also works in most cases.
GRAPH_TENANT_ID=common

# --- Anthropic (Claude) ---
# Optional. Without it, the tool classifies titles with keyword matching instead.
ANTHROPIC_API_KEY=
# Cheap + fast model for classification. Override if you prefer another.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Email options ---
# Text (faithful to the template wording) or HTML (richer formatting).
BODY_TYPE=Text
# Optional one-line signature if you don't use signature.txt.
SENDER_SIGNATURE=

# --- Follow-ups ---
# Days between consecutive emails (gap before each follow-up). 5 values = 5 follow-ups.
FOLLOWUP_INTERVALS=2,5,7,10,20

# --- Cloud hosting only (leave blank for local desktop use) ---
# Set by Render automatically from the Postgres add-on. When present, the tool
# uses Postgres + DB-backed token storage instead of local SQLite/file.
DATABASE_URL=
# Password to protect the hosted web UI (HTTP basic auth). Required in the cloud.
APP_PASSWORD=
# Secret for the daily follow-up trigger URL (/api/cron/followups?token=...).
# An external free scheduler (cron-job.org, GitHub Actions) calls it once a day.
CRON_TOKEN=
# Seconds between follow-up sends during a cron run (optional).
FOLLOWUP_DELAY=2
